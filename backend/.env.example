DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/cityreport
SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Analysis — set your key to enable Grok vision analysis
# xAI Grok key (starts with xai-): https://console.x.ai
# Groq key (starts with gsk_):     https://console.groq.com
GROK_API_KEY=

# Production CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend-domain.com

# Local ML models — leave empty until you have trained weights
ROAD_DETECTOR_WEIGHTS=
ROAD_DEPTH_MODEL=
ROAD_SEVERITY_MODEL=
ROAD_MODEL_DEVICE=
